rules_version = '2';

// 참고(보안 관련 한계):
// - v1 사용자(조교)는 인증된 사용자라면 누구나 예약을 생성/수정/삭제할 수 있습니다.
//   (소규모 신뢰 그룹 가정)
// - 시간 겹침(conflict) 차단은 클라이언트에서만 수행되며, 동시 예약 경쟁 상태는
//   v1에서 허용된 한계입니다.
// - 소유자(createdByUid)는 수정 시 변경 불가(immutable)하도록 강제합니다.

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isNonEmptyString(value) {
      return value is string && value.size() > 0;
    }

    function validReservation(data) {
      return data.startSlot is int
        && data.endSlot is int
        && data.startSlot >= 0 && data.startSlot <= 27
        && data.endSlot >= 1 && data.endSlot <= 28
        && data.endSlot > data.startSlot
        && data.date is string
        && data.date.matches('^[0-9]{4}-[0-9]{2}-[0-9]{2}$')
        && isNonEmptyString(data.roomId)
        && isNonEmptyString(data.bookedFor)
        && isNonEmptyString(data.createdByUid)
        // 용도(선택): 문자열이며 80자 이하
        && data.get('purpose', '') is string
        && data.get('purpose', '').size() <= 80
        // 그룹 id(선택): 다일/반복 묶음 식별자
        && data.get('groupId', '') is string;
    }

    // 회의실: 인증된 사용자 읽기 가능, 쓰기는 콘솔/시드 스크립트로만(클라이언트 불가)
    match /rooms/{roomId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // 사용자(명단): 인증된 사용자 읽기 가능, 쓰기는 콘솔/시드 스크립트로만
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // 예약
    match /reservations/{reservationId} {
      allow read: if isSignedIn();

      allow create: if isSignedIn()
        && validReservation(request.resource.data)
        && request.resource.data.createdByUid == request.auth.uid;

      // 소유자(createdByUid)는 변경 불가
      allow update: if isSignedIn()
        && validReservation(request.resource.data)
        && request.resource.data.createdByUid == resource.data.createdByUid;

      allow delete: if isSignedIn();
    }
  }
}
