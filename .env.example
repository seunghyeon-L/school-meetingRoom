# Firebase 웹 앱 설정 (Firebase 콘솔 > 프로젝트 설정 > 웹 앱에서 복사)
VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:abcdef0123456789

# App Check reCAPTCHA v3 사이트 키 (App Check 사용 시)
VITE_RECAPTCHA_SITE_KEY=your-recaptcha-v3-site-key

# 로컬 에뮬레이터 사용 시 'true' (App Check 비활성화)
VITE_USE_EMULATOR=false
